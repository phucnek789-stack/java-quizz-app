<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" prefHeight="329.0" prefWidth="271.0" spacing="20.0" styleClass="Container" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/18" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pnhp.quizapp.PrimaryController">
   <children>
      <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="Subject" text="EnglishApp">
         <font>
            <Font size="40.0" />
         </font>
      </Text>
      <Button mnemonicParsing="false" onAction="#ManageQuestion" styleClass="Button" text="Quản lý câu hỏi">
         <font>
            <Font size="20.0" />
         </font>
      </Button>
      <Button mnemonicParsing="false" onAction="#Practice" styleClass="Button" text="Luyện tập">
         <font>
            <Font size="20.0" />
         </font>
      </Button>
      <Button mnemonicParsing="false" onAction="#Exam" styleClass="Button" text="Luyện thi">
         <font>
            <Font size="20.0" />
         </font>
      </Button>
      <ComboBox fx:id="cbThemes" onAction="#changeTheme" prefWidth="150.0" styleClass="ComboBox" />
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
